
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks collaboratorIds on the budget document via get().
     * Safe: guards with 'is list' so a missing field returns false instead of error.
     */
    function isCollaborator(ownerId, budgetId) {
      let budgetData = get(/databases/$(database)/documents/users/$(ownerId)/budgets/$(budgetId)).data;
      return isSignedIn()
             && budgetData != null
             && budgetData.collaboratorIds is list
             && (request.auth.uid in budgetData.collaboratorIds);
    }

    /**
     * Firestore rules DO evaluate both sides of ||.
     * However, the isCollaborator function is now safe because it guards
     * against missing data with 'budgetData != null' and 'is list' checks.
     */
    function hasAccess(userId, budgetId) {
      return isOwner(userId) || isCollaborator(userId, budgetId);
    }

    function isValidRsvpDocument(budgetId) {
        let data = request.resource.data;
        return data.guestName is string &&
               data.guestName.size() > 0 &&
               data.status is string &&
               (data.status == 'attending' || data.status == 'not_attending') &&
               data.additionalGuests is number &&
               data.additionalGuests >= 0 &&
               data.budgetId == budgetId &&
               request.time == data.respondedAt;
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Allow searching for users by email to add them as collaborators
      allow list: if isSignedIn();
      allow get, update, delete: if isOwner(userId);
      allow create: if isOwner(userId);

      match /budgets/{budgetId} {
        // Public read for RSVP, owner/collaborator for others
        allow get: if true;
        allow list: if isOwner(userId);
        allow create, delete: if isOwner(userId);
        allow update: if hasAccess(userId, budgetId);

        match /categories/{categoryId} {
          allow get, list, create, update, delete: if hasAccess(userId, budgetId);
          match /items/{itemId} {
             allow get, list, create, update, delete: if hasAccess(userId, budgetId);
          }
        }
        match /mustDos/{mustDoId} {
          allow get, list, create, update, delete: if hasAccess(userId, budgetId);
        }
        match /rsvps/{rsvpId} {
            allow create: if isValidRsvpDocument(budgetId);
            allow get, list, update, delete: if hasAccess(userId, budgetId);
        }
      }
    }
  }
}
  