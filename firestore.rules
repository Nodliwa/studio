
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is a collaborator on the budget.
     * Safely checks for existence and field presence to avoid rule errors.
     */
    function isCollaborator(ownerId, budgetId) {
      let path = /databases/$(database)/documents/users/$(ownerId)/budgets/$(budgetId);
      return isSignedIn() && 
             exists(path) && 
             request.auth.uid in get(path).data.get('collaboratorIds', []);
    }

    function hasAccess(userId, budgetId) {
      return isOwner(userId) || isCollaborator(userId, budgetId);
    }

    function isValidRsvpDocument(budgetId) {
        let data = request.resource.data;
        return data.guestName is string &&
               data.guestName.size() > 0 &&
               data.status is string &&
               (data.status == 'attending' || data.status == 'not_attending') &&
               data.additionalGuests is number &&
               data.additionalGuests >= 0 &&
               data.budgetId == budgetId &&
               (data.respondedAt == request.time || data.respondedAt == null); // Handle potential timestamp delay
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Allow searching for users by email to add them as collaborators
      allow list: if isSignedIn();
      allow get, update, delete: if isOwner(userId);
      allow create: if isOwner(userId);

      match /budgets/{budgetId} {
        // Owner has full control
        allow read, write: if isOwner(userId);
        
        // Public read for RSVP pages, others need collaborator access
        allow get: if true; 
        allow list: if isCollaborator(userId, budgetId);
        allow update: if isCollaborator(userId, budgetId);

        match /categories/{categoryId} {
          allow read, write: if hasAccess(userId, budgetId);
          match /items/{itemId} {
             allow read, write: if hasAccess(userId, budgetId);
          }
        }
        match /mustDos/{mustDoId} {
          allow read, write: if hasAccess(userId, budgetId);
        }
        match /rsvps/{rsvpId} {
            allow create: if isValidRsvpDocument(budgetId);
            allow read, update, delete: if hasAccess(userId, budgetId);
        }
      }
    }
  }
}
