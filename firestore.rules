
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is a collaborator on the budget.
     * Uses a cross-document lookup to the parent budget document.
     */
    function isCollaborator(ownerId, budgetId) {
      let budgetPath = /databases/$(database)/documents/users/$(ownerId)/budgets/$(budgetId);
      return isSignedIn() && 
             exists(budgetPath) && 
             request.auth.uid in get(budgetPath).data.get('collaboratorIds', []);
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Allow searching for users by email to add them as collaborators
      allow list: if isSignedIn();
      // Owner has full control over their profile
      allow get, write: if isOwner(userId);

      match /budgets/{budgetId} {
        // Owners have full control over their own budgets
        allow read, write: if isOwner(userId);
        
        // Public read access for specific budget metadata (needed for RSVP pages)
        allow get: if true; 

        // Collaborators can view and update shared budgets
        allow read, update: if isCollaborator(userId, budgetId);

        match /categories/{allPaths=**} {
          allow read, write: if isOwner(userId) || isCollaborator(userId, budgetId);
        }
        
        match /mustDos/{mustDoId} {
          allow read, write: if isOwner(userId) || isCollaborator(userId, budgetId);
        }
        
        match /rsvps/{rsvpId} {
            // RSVPs can be submitted by anyone with the link
            allow create: if request.resource.data.budgetId == budgetId;
            // Only owner and collaborators can see or manage the guest list
            allow read, update, delete: if isOwner(userId) || isCollaborator(userId, budgetId);
        }
      }
    }
  }
}
