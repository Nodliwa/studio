
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is a collaborator on the budget.
     */
    function isCollaborator(ownerId, budgetId) {
      let path = /databases/$(database)/documents/users/$(ownerId)/budgets/$(budgetId);
      return isSignedIn() && exists(path) && (request.auth.uid in get(path).data.get('collaboratorIds', []));
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Owner has full control over their profile and everything under it
      allow read, write: if isOwner(userId);
      // Allow searching for users by email to add them as collaborators
      allow list: if isSignedIn();

      match /budgets/{budgetId} {
        // Owners and collaborators can read/write budgets
        allow read, write: if isOwner(userId) || isCollaborator(userId, budgetId);
        
        // Public get access for specific budget metadata (needed for RSVP pages)
        allow get: if true; 

        // Subcollections (categories, items, mustDos, rsvps)
        match /{allPaths=**} {
          allow read, write: if isOwner(userId) || isCollaborator(userId, budgetId);
        }
        
        match /rsvps/{rsvpId} {
            // RSVPs can be submitted by anyone with the link
            allow create: if true;
        }
      }
    }
  }
}
