
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is the owner or an authorized collaborator
    function canAccessBudget(userId, budgetId) {
      let budget = get(/databases/$(database)/documents/users/$(userId)/budgets/$(budgetId)).data;
      return request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email in budget.collaboratorEmails
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /budgets/{budgetId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId || 
          request.auth.token.email in resource.data.collaboratorEmails ||
          request.auth.token.email in request.resource.data.collaboratorEmails
        );

        match /categories/{categoryId} {
          allow read, write: if canAccessBudget(userId, budgetId);
          match /items/{itemId} {
            allow read, write: if canAccessBudget(userId, budgetId);
          }
        }

        match /mustDos/{mustDoId} {
          allow read, write: if canAccessBudget(userId, budgetId);
        }

        match /rsvps/{rsvpId} {
          allow read, update, delete: if canAccessBudget(userId, budgetId);
          allow create: if true; // Guests can RSVP
        }
      }
    }
  }
}
