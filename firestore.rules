
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is a collaborator on the budget.
     * Uses a direct lookup on the budget document's collaboratorIds array.
     */
    function isCollaborator(ownerId, budgetId) {
      let budgetPath = /databases/$(database)/documents/users/$(ownerId)/budgets/$(budgetId);
      return isSignedIn() && exists(budgetPath) && (request.auth.uid in get(budgetPath).data.get('collaboratorIds', []));
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Allow searching for users by email to add them as collaborators
      allow list: if isSignedIn();
      // Owner has full control over their profile
      allow get, write: if isOwner(userId);

      match /budgets/{budgetId} {
        // Owners have full control over their own budgets (includes create, update, delete)
        allow read, write: if isOwner(userId);
        
        // Public read access for specific budget metadata (needed for RSVP pages)
        allow get: if true; 

        // Collaborators can view and update shared budgets
        allow read, update: if isCollaborator(userId, budgetId);

        // Subcollections (categories, items, mustDos, rsvps)
        match /{allPaths=**} {
          allow read, write: if isOwner(userId) || isCollaborator(userId, budgetId);
        }
        
        match /rsvps/{rsvpId} {
            // RSVPs can be submitted by anyone with the link
            allow create: if true;
        }
      }
    }
  }
}
